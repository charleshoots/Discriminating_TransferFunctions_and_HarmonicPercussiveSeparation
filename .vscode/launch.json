{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
          "name": "Python: Current File",
          "type": "python",
          "request": "launch",
          "program": "${file}",
          "console": "integratedTerminal",
          "justMyCode": false,  // Ensure this is set to false to allow stepping into library code
          "stopOnEntry": false,  // Set to true if you want to stop at the first line of the program
          "env": {
            "PYTHONBREAKPOINT": "pdb.set_trace"  // Use pdb for breakpoints
          },
          "envFile": "${workspaceFolder}/.env",  // Load environment variables from a .env file
          "args": [],  // Add any program arguments here
          "cwd": "${workspaceFolder}",  // Set the working directory
          "debugOptions": [
            "RedirectOutput",
            "ShowReturnValue"
          ]
        }
      ],
"debugpy.debugJustMyCode": false,
"debug.allowBreakpointsEverywhere": true,
"purpose": ["debug-in-terminal"]
}