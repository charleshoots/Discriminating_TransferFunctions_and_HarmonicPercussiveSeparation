#!/bin/csh
#=================================================================================
set calc = "yes"
# bad data on 6/17
#----------------------------------------------------------------------------------
set R = -97/-88.5/-3/3
set I = 0.01
# note the extension "llf" stands for lon, lat, maganom 

if ($calc == "yes" ) then 
 /bin/rm maganom.llf tmp
 awk '{print $1 "  " $2 "  " $5}' /Volumes/scienceparty_share/SR2411_scienceparty_share/Grav_Mag/DATA/Processed_Daily_Grav/0701tot_mag.txt > maganom.llm
 gmt blockmean maganom.llm -I$I -R$R >! tmp
 /bin/rm -f .grd
 #surface tmp -Gboug.grd -I$I -R$R -T0.25
gmt nearneighbor tmp -Gmaganom.grd -N1 -I$I -R$R -S0.05 -Vl 
endif
#----------------------------------------------------------------------------------
gmt gmtset PS_PAGE_ORIENTATION portrait PROJ_LENGTH_UNIT inch 
gmt gmtset FORMAT_GEO_MAP D FONT_HEADING 11 COLOR_NAN 180
gmt gmtset MAP_ANNOT_OFFSET_PRIMARY 3p MAP_ANNOT_OFFSET_SECONDARY 3p MAP_FRAME_PEN thin,black MAP_DEFAULT_PEN thin,black


set proj = "M5.5"
set grdfile = maganom.grd
set psfile = maganom
set gradfile = junk.grd

set cpt = "maganom.cpt"
gmt makecpt -CSCM/vik -T-500/500/50 >! $cpt

set Btop = "pa1f0SWen"

gmt grdgradient $grdfile -G$gradfile -A325 -N15 -V
#gmt grdgradient satmaganom.grd -Gsatgrad.grd -A325 -N4 -V


#gmt grdimage satmaganom.grd -Isatgrad.grd -J$proj -R$R -C$cpt -X0.7 -Y4 -K >! $psfile.ps 
#gmt grdimage satmaganom.grd -J$proj -R$R -C$cpt -X0.7 -Y4 -K  >! $psfile.ps 
#gmt grdimage $grdfile -J$proj -R$R -C$cpt -K -O -Q >> $psfile.ps
gmt grdimage $grdfile -I$gradfile -J$proj -R$R -C$cpt -K -X0.7 -Y4 -V >! $psfile.ps
gmt grdcontour regional.grd -C1 -J$proj -R$R -Wthinnest,gray70 -O -K -Vl >> $psfile.ps

gmt psxy Sinton_axis.xy -J -R -Wthinner,0 -K -O -V >> $psfile.ps

gmt gmtset D_FORMAT %.0f
gmt pscoast -J$proj -R -W0.5,0 -G120/90/70 -Df -O  -K >> $psfile.ps
gmt psscale -D3/-0.3/4.5/0.1h -C$cpt -B100f20:"Total Magnetic Field Anomaly (nT)": -V -O -K >> $psfile.ps

gmt gmtset -Vl FORMAT_FLOAT_OUT %.0f
gmt gmtset ANNOT_FONT_SIZE_PRIMARY 10p
gmt psbasemap -R$R -J$proj -B$Btop -O >> $psfile.ps

gmt gmtset -Vl FORMAT_FLOAT_OUT %.6f


gmt psconvert -Tf $psfile.ps
gv $psfile.pdf &

/bin/rm $psfile.ps

